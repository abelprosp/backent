{
  "name": "@backent/database",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "generate": "dotenv -e ../../.env -- prisma generate",
    "migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "push": "dotenv -e ../../.env -- prisma db push",
    "seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "studio": "prisma studio",
    "build": "tsc"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0"
  },
  "devDependencies": {
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "bcryptjs": "^2.4.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "dotenv-cli": "^8.0.0"
  }
}
