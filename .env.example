# ─── Platform Database ───────────────────────────────────────
DATABASE_URL="postgresql://backent:backent_secret@localhost:5432/backent_platform?schema=platform"

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── JWT ─────────────────────────────────────────────────────
# Em produção: use strings aleatórias com 64+ caracteres (openssl rand -hex 32)
JWT_SECRET="change-me-to-a-64-char-random-string-in-production-please"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-refresh-secret-in-production-please"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── MinIO / S3 ──────────────────────────────────────────────
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="backent_minio"
MINIO_SECRET_KEY="backent_minio_secret"
MINIO_BUCKET="backent-storage"
MINIO_USE_SSL=false

# ─── API ─────────────────────────────────────────────────────
API_PORT=4000
API_URL="http://localhost:4000"
CORS_ORIGINS="http://localhost:3000,http://localhost:3001,http://localhost:3002"
# Produção: liste apenas origens confiáveis, separadas por vírgula

# ─── Frontend URLs ───────────────────────────────────────────
WEB_URL="http://localhost:3000"
ADMIN_URL="http://localhost:3001"
LANDING_URL="http://localhost:3002"
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"

# ─── Stripe (future) ─────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ─── Mercado Pago (future) ───────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=""

# ─── Email (magic link) ──────────────────────────────────────
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="noreply@backent.io"

# ─── Observability ───────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD="admin"
PROMETHEUS_RETENTION="15d"
